# Backend (FastAPI) — копируйте в backend/.env или корень при docker-compose
SQLITE_PATH=data/encar.db
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ENCAR job (см. backend/app/jobs/fetch_encar.py)
ENCAR_LIST_URL=https://api.encar.com/search/car/list/premium
ENCAR_SEARCH_QUERY=(And.Hidden.N._.CarType.N.)
ENCAR_SORT=ModifiedDate
ENCAR_PAGE_SIZE=20
ENCAR_MAX_PAGES=5
ENCAR_REQUEST_DELAY_SEC=1.0
ENCAR_USER_AGENT=ENCAR-LandingBot/1.0 (contact@example.com)
ENCAR_PHOTO_BASE=https://ci.encar.com
# Ссылка «Смотреть на ENCAR» ({car_id} = Id из SearchResults; по умолчанию fem.encar.com)
ENCAR_DETAIL_URL_TEMPLATE=https://fem.encar.com/cars/detail/{car_id}

# Frontend
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# VPS: docker-compose.ghcr.yml (образы → ghcr.io, Jenkins или вручную)
# GHCR_OWNER=alex-zaporozhan
# IMAGE_TAG=latest

# VPS: docker-compose.hub.yml (образы из GitHub Actions → Docker Hub)
# DOCKERHUB_USER=yourdockerhublogin
# IMAGE_TAG=latest
